:80 {
    redir https://{host}{uri} permanent
}

{$DOMAIN} {
    tls internal

    handle /amory/api/* {
        uri strip_prefix /amory
        reverse_proxy backend:8000
    }
    handle /uploads/* {
        reverse_proxy backend:8000
    }
    handle /amory/* {
        uri strip_prefix /amory
        reverse_proxy frontend:80
    }
    handle /amory {
        redir /amory/ permanent
    }
}
