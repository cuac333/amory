# ───── Secrets / env ─────
.env
.env.local
.env.*
**/.env
**/.env.local
**/.env.*
# ALWAYS commit the example template (must come after the patterns above)
!.env.example
!**/.env.example

# Deploy scripts (contain credentials) — keep local only
/scripts
/scripts/

# Keys / certs
*.pem
*.key
*.p12
*.cert
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ───── Python ─────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
*.egg-info/

# ───── Node / Vite ─────
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# ───── Database / dumps ─────
*.db
*.sqlite
*.sqlite3
*.sql
*.dump
amory.db

# ───── User-uploaded content (regenerated at runtime) ─────
**/uploads/
backend/app/uploads/
!backend/app/uploads/.gitkeep

# ───── Build / package bundles ─────
*.tar.gz
*.tar
*.zip
amory-deploy.tar.gz

# ───── IDE / editor ─────
.idea/
.vscode/
*.swp
*.swo
*~

# ───── OS ─────
.DS_Store
Thumbs.db
desktop.ini

# ───── Claude / AI assistants ─────
.claude/

