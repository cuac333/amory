# Amory Environment Variables
# Copy this file to .env and fill in the values

# Domain (used by Caddy for automatic HTTPS)
DOMAIN=amory.tudominio.com

# Database
DB_PASSWORD=cambia_esta_password_segura

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=cambia_esta_clave_secreta

# CORS (your domain with https)
CORS_ORIGINS=https://amory.tudominio.com

# VAPID keys for push notifications (generate at https://vapidkeys.com)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tu@email.com
